
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- SECURITY HELPERS ---
    
    // Checks if the user is authenticated with Firebase Auth.
    function isSignedIn() {
      return request.auth != null;
    }

    // --- COLLECTIONS ---

    // Security Configuration
    match /adminConfig/security {
      // Allow authenticated admins to update the password.
      // Get is restricted but allowed for authenticated sessions to verify status.
      allow get: if isSignedIn();
      allow update: if isSignedIn();
      allow create, delete: if false; 
    }

    // Gallery Artworks
    match /artworks/{artworkId} {
      allow get, list: if true; // Publicly viewable
      allow create, update, delete: if isSignedIn(); // Requires active admin session
    }

    // Club Events
    match /events/{eventId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    // Member registrations
    match /members/{memberId} {
      allow create: if true; // Public access for registration
      allow get, list, update, delete: if isSignedIn(); // Restricted to admins
    }

    // Shop Products
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    // Customer Orders
    match /orders/{orderId} {
      allow create: if true; // Public access for customers
      allow get, list, update, delete: if isSignedIn(); // Restricted to admins
    }

    // Public Club Settings
    match /clubSettings/global {
      allow get: if true;
      allow list: if true;
      allow create, update: if isSignedIn();
    }
  }
}

// --- STORAGE RULES ---
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Public read access for assets, write access restricted to admins
      allow read: if true;
      allow write: if request.auth != null && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
